{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://the-turf-in.onrender.com/api/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/client/$1"
        }
    ],
    "env": {
        "REACT_APP_API_URL": "https://the-turf-in.onrender.com",
        "CI": "false",
        "NODE_OPTIONS": "--max-old-space-size=4096"
    }
}
{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "client/build",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://the-turf-in.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://the-turf-in.onrender.com",
    "CI": "false",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "GENERATE_SOURCEMAP": "false"
  }
}